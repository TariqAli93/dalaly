{
  "name": "@dalaly/server",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "node scripts/clean-dist.mjs && tsup",
    "start": "node dist/index.js",
    "db:migrate": "tsx src/infrastructure/database/migrate.ts",
    "db:generate": "drizzle-kit generate",
    "lint": "tsc -p tsconfig.json --noEmit",
    "test:runtime": "node scripts/runtime-smoke.mjs",
    "test:runtime:phase1": "node scripts/runtime-smoke-phase1.mjs",
    "test:runtime:phase2": "node scripts/runtime-smoke-phase2.mjs",
    "test:runtime:spaces": "node scripts/runtime-smoke-spaces.mjs",
    "clean": "node scripts/clean-dist.mjs"
  },
  "dependencies": {
    "@fastify/cors": "^11.1.0",
    "adm-zip": "^0.5.16",
    "dotenv": "^17.2.3",
    "drizzle-orm": "^0.45.2",
    "fastify": "^5.6.2",
    "pg": "^8.16.3",
    "zod": "^4.1.12"
  },
  "devDependencies": {
    "@types/adm-zip": "^0.5.7",
    "@types/node": "^24.10.1",
    "@types/pg": "^8.15.6",
    "drizzle-kit": "^0.31.8",
    "tsup": "^8.5.1",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3"
  }
}
