{
  "name": "@dalaly/desktop",
  "version": "0.1.0",
  "private": true,
  "description": "Dalaly Windows desktop application shell.",
  "author": "Dalaly",
  "type": "module",
  "main": "src/main.js",
  "scripts": {
    "dev": "cross-env VITE_DEV_SERVER_URL=http://127.0.0.1:5173 electron ./src/main.js",
    "start": "electron ./src/main.js",
    "build": "electron-builder --win nsis portable --publish never",
    "package": "electron-builder --win nsis portable --publish never",
    "package:portable": "electron-builder --win portable --publish never",
    "package:installer": "electron-builder --win nsis --publish never",
    "release": "electron-builder --win nsis portable --publish never",
    "clean": "node -e \"require('node:fs').rmSync('release',{recursive:true,force:true})\""
  },
  "dependencies": {
    "electron-log": "^5.4.4",
    "nodemailer": "^6.9.16"
  },
  "devDependencies": {
    "cross-env": "^10.1.0",
    "electron": "39.8.10",
    "electron-builder": "^26.8.1"
  },
  "build": {
    "appId": "codel.dalaly.desktop",
    "productName": "Dalaly",
    "asar": true,
    "compression": "normal",
    "directories": {
      "output": "release",
      "buildResources": "build"
    },
    "files": [
      "src/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "../../server/dist",
        "to": "server/dist",
        "filter": [
          "**/*"
        ]
      },
      {
        "from": "../../server/drizzle",
        "to": "server/drizzle",
        "filter": [
          "**/*"
        ]
      },
      {
        "from": "../renderer/dist",
        "to": "renderer/dist",
        "filter": [
          "**/*"
        ]
      },
      {
        "from": "../../tools",
        "to": "tools",
        "filter": [
          "**/*"
        ]
      }
    ],
    "publish": null,
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "build/icon.ico",
      "artifactName": "Dalaly-${version}-${arch}.${ext}"
    },
    "portable": {
      "artifactName": "Dalaly-Portable-${version}-${arch}.${ext}"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Dalaly",
      "installerIcon": "build/icon.ico",
      "uninstallerIcon": "build/icon.ico",
      "artifactName": "Dalaly-Setup-${version}-${arch}.${ext}"
    }
  }
}
